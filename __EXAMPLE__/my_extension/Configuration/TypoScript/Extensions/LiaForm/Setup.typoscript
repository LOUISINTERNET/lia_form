@import 'EXT:form/Configuration/TypoScript/'

# lia_form and project form YAML configurations are registered via
# auto-discovery (Configuration/Form/<SetName>/config.yaml) since TYPO3
# v14.2 — no TypoScript registration needed anymore. See
# EXT:my_extension/Configuration/Form/MyExtensionForms/config.yaml for the
# project-specific configuration set (priority 150, loads between
# lia/lia-form-setup and lia/lia-form-elements).
