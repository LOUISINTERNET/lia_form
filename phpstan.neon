includes:
    - .Build/vendor/phpstan/phpstan-phpunit/extension.neon
    - .Build/vendor/phpstan/phpstan-deprecation-rules/rules.neon
    - .Build/vendor/saschaegerer/phpstan-typo3/extension.neon

parameters:
    level: 5

    paths:
        - Classes
        - Configuration
        - ext_localconf.php

    excludePaths:
        analyseAndScan:
            - .Build
            - vendor (?)
            - __EXAMPLE__ (?)

    treatPhpDocTypesAsCertain: false
